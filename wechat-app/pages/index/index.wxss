/* 紫微斗数 AI 小程序 - 样式 */
page {
  background: #0a0a1a;
  color: #e0dce8;
  font-family: -apple-system, 'Noto Sans SC', sans-serif;
  min-height: 100vh;
}

/* ─── 通用 ─── */
.page { padding: 30rpx 24rpx 60rpx; }
.card {
  background: rgba(20, 15, 40, 0.85);
  border: 1rpx solid rgba(120, 80, 180, 0.4);
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(20px);
}

/* ─── 首页 ─── */
.hero { text-align: center; padding: 50rpx 0 30rpx; }
.hero-icon { font-size: 64rpx; display: block; margin-bottom: 10rpx; }
.hero-title { font-size: 48rpx; font-weight: 700; color: #f0d68a; display: block; }
.hero-subtitle { font-size: 26rpx; color: #9088a0; display: block; margin-top: 10rpx; }

.form-group { margin-bottom: 30rpx; }
.form-label { display: block; font-size: 26rpx; color: #b0a8c8; margin-bottom: 10rpx; }
.form-picker {
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(120, 80, 180, 0.4);
  border-radius: 16rpx;
  color: #e0dce8; font-size: 30rpx;
}
.form-input {
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(120, 80, 180, 0.4);
  border-radius: 16rpx;
  color: #e0dce8; font-size: 30rpx;
  width: 100%; box-sizing: border-box;
}

.gender-row { display: flex; gap: 20rpx; }
.gender-btn {
  flex: 1; text-align: center; padding: 24rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(120, 80, 180, 0.4);
  border-radius: 16rpx;
  color: #b0a8c8; font-size: 30rpx;
  transition: all 0.3s;
}
.gender-btn.active {
  background: rgba(124,58,237,0.3);
  border-color: #a855f7;
  color: #fff;
}

.btn-primary {
  text-align: center; padding: 28rpx;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  border-radius: 24rpx;
  color: #fff; font-size: 34rpx; font-weight: 600;
  margin-top: 20rpx;
}

.quota-bar { text-align: center; padding: 20rpx 0; }
.quota-text { font-size: 24rpx; color: #6b6080; margin: 0 16rpx; }
.quota-text.exhausted { color: #ff6b6b; }

.footer-text { text-align: center; padding: 40rpx 0; }
.footer-text text { display: block; font-size: 22rpx; color: #504878; line-height: 1.6; }

/* ─── 结果页 ─── */
.back-bar { display: flex; align-items: center; padding-bottom: 20rpx; }
.back-btn { font-size: 44rpx; color: #9088a0; padding: 0 16rpx; }
.back-title { font-size: 28rpx; color: #9088a0; }

.card-title { font-size: 30rpx; font-weight: 600; color: #f0d68a; display: block; }
.card-info { font-size: 22rpx; color: #9088a0; display: block; margin-top: 6rpx; }

/* 星盘图 */
.star-chart { display: flex; flex-wrap: wrap; margin-top: 16rpx; }
.chart-cell {
  width: 25%; text-align: center;
  padding: 14rpx 4rpx; font-size: 22rpx;
  border: 1rpx solid rgba(120,80,180,0.25);
  background: rgba(255,255,255,0.03);
  box-sizing: border-box; line-height: 1.4;
}
.chart-cell.ming { border-color: #d4a853; background: rgba(212,168,83,0.08); }
.cell-name { color: #9088a0; font-size: 20rpx; display: block; }
.chart-cell.ming .cell-name { color: #f0d68a; }
.cell-star { color: #e0dce8; font-size: 24rpx; font-weight: 600; display: block; margin-top: 4rpx; }
.chart-hint { font-size: 20rpx; color: #6b6080; text-align: center; display: block; margin-top: 12rpx; }

/* Tab 栏 */
.tab-card { display: flex; padding: 4rpx; overflow: hidden; }
.tab {
  flex: 1; text-align: center; padding: 20rpx 2rpx;
  font-size: 24rpx; color: #9088a0;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}
.tab.active { color: #f0d68a; border-bottom-color: #d4a853; }

/* 解读内容 */
.reading-card { min-height: 200rpx; }
.loading-area { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.spinner {
  width: 60rpx; height: 60rpx;
  border: 4rpx solid rgba(212,168,83,0.2);
  border-top-color: #d4a853;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 26rpx; color: #9088a0; margin-top: 20rpx; }

.reading-richtext { font-size: 28rpx; color: #d8d4e8; line-height: 1.8; }

.disclaimer {
  font-size: 22rpx; color: #6b6080;
  text-align: center; display: block;
  margin-top: 30rpx; line-height: 1.6;
}
